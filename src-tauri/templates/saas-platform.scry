  "groups": [
    {
      "id": "group-1",
      "kind": "deployment",
      "name": "Next.js App",
      "description": "Dashboard and Chat API share a single Next.js deployment",
      "memberIds": [
        "node-10",
        "node-11"
      ]
    },
    {
      "id": "d93a9d8b-8718-4c2b-aa34-5122c8db7961",
