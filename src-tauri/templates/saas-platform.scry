  ],
  "flows": [
    {
      "id": "scenario-1",
      "name": "Chat with a deployed bot",
      "description": "An end user sends a message through the widget and receives a streamed AI response",
      "steps": [
        {
          "id": "step-1",
          "description": "@[End User] types a message in the @[Widget] on a customer's website"
        },
        {
          "id": "step-2",
          "description": "@[Widget] sends the message and session ID to the @[Chat API]"
        },
        {
          "id": "step-3",
          "description": "@[handleChatMessage] validates the bot ID and checks the owner's usage quota"
        },
        {
          "id": "step-4",
          "description": "@[searchChunks] embeds the query and retrieves relevant @[KnowledgeChunk] records from the @[Database]"
        },
        {
          "id": "step-5",
          "description": "@[Chat Handler] builds the prompt with the @[Bot] system prompt, retrieved context, and conversation history"
        },
        {
          "id": "step-6",
          "description": "@[Chat Handler] streams the response from @[OpenAI] back through the @[Widget]"
        },
        {
          "id": "step-7",
          "description": "@[Conversations] logs the @[Message] pair in the @[Database]"
        }
      ]
    },
    {
      "id": "scenario-2",
      "name": "Upload knowledge base document",
      "description": "A user uploads a document that gets chunked, embedded, and made available to their bot",
      "steps": [
        {
          "id": "step-1",
          "description": "@[User] uploads a document in the @[Dashboard] knowledge base section"
        },
        {
          "id": "step-2",
          "description": "@[ingestDocument] splits the document into ~500-token chunks"
        },
        {
          "id": "step-3",
          "description": "@[ingestDocument] sends each chunk to @[OpenAI] for embedding generation"
        },
        {
          "id": "step-4",
          "description": "@[Knowledge Base] stores the @[KnowledgeChunk] records with their vectors in the @[Database]"
        },
        {
          "id": "step-5",
          "description": "The bot can now answer questions using the uploaded content"
        }
      ]
    }
  ],
  "contract": {
    "expect": [
      "All data access is scoped to the authenticated user's bots",
      "LLM responses are streamed \u2014 never buffer the full response before sending",
      "Webhook handlers are idempotent \u2014 safe to process duplicate events"
    ],
    "never": [
      "Expose a bot's system prompt or raw knowledge base content to end users",
      "Call the LLM without checking the owner's usage quota first"
    ]
  },
