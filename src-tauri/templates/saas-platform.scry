{
  "nodes": [
    {
      "id": "node-1",
      "type": "c4",
      "position": {
        "x": 600,
        "y": -420
      },
      "data": {
        "name": "User",
        "description": "Creates chatbots, configures their behavior, and monitors conversations",
        "kind": "person"
      }
    },
    {
      "id": "node-2",
      "type": "c4",
      "position": {
        "x": 220,
        "y": -80
      },
      "data": {
        "name": "End User",
        "description": "Chats with a deployed bot via the embeddable widget",
        "kind": "person"
      }
    },
    {
      "id": "node-3",
      "type": "c4",
      "position": {
        "x": 600,
        "y": -80
      },
      "data": {
        "name": "Chatbot Platform",
        "description": "SaaS platform where users create AI chatbots, train them on their own content, and deploy them as embeddable widgets",
        "kind": "system",
        "status": "proposed"
      }
    },
    {
      "id": "node-4",
      "type": "c4",
      "position": {
        "x": 980,
        "y": -80
      },
      "data": {
        "name": "OpenAI",
        "description": "LLM provider for chat completions and embeddings",
        "kind": "system",
        "external": true
      }
    },
    {
      "id": "node-5",
      "type": "c4",
      "position": {
        "x": 600,
        "y": 240
      },
      "data": {
        "name": "Stripe",
        "description": "Subscription billing and payment processing",
        "kind": "system",
        "external": true
      }
    },
    {
      "id": "node-10",
      "type": "c4",
      "position": {
        "x": 260,
        "y": -760
      },
      "data": {
        "name": "Dashboard",
        "description": "Admin interface where users manage bots, upload knowledge base documents, view conversation logs, and manage billing",
        "kind": "container",
        "technology": "Payload CMS, Next.js",
        "status": "proposed"
      },
      "parentId": "node-3"
    },
    {
      "id": "node-11",
      "type": "c4",
      "position": {
        "x": 260,
        "y": -420
      },
      "data": {
        "name": "Chat API",
        "description": "Handles inbound chat messages, retrieves context from the knowledge base, and streams LLM responses",
        "kind": "container",
        "technology": "Next.js API Routes",
        "status": "proposed"
      },
      "parentId": "node-3"
    },
    {
      "id": "node-12",
      "type": "c4",
      "position": {
        "x": -80,
        "y": -760
      },
      "data": {
        "name": "Widget",
        "description": "Embeddable chat widget that end users interact with on the customer's website",
        "kind": "container",
        "technology": "React, iframe",
        "status": "proposed",
        "contract": {
          "expect": [
            "Widget loads via a single script tag with a bot ID",
            "Chat state persists across page navigations using sessionStorage"
          ],
          "never": [
            "Access the host page DOM outside the iframe boundary"
          ]
        }
      },
      "parentId": "node-3"
    },
    {
      "id": "node-13",
      "type": "c4",
      "position": {
        "x": 600,
        "y": -420
      },
      "data": {
        "name": "Database",
        "description": "Stores user accounts, bot configs, knowledge base documents, and conversation logs",
        "kind": "container",
        "technology": "MongoDB",
        "shape": "cylinder",
        "status": "proposed",
        "contract": {
          "expect": [
            "All queries are scoped to the authenticated user's bots",
            "Conversation logs are TTL-indexed for automatic cleanup"
          ]
        }
      },
      "parentId": "node-3"
    },
    {
      "id": "node-20",
      "type": "c4",
      "position": {
        "x": -80,
        "y": 600
      },
      "data": {
        "name": "Bots",
        "description": "Payload collection for chatbot configurations \u2014 name, system prompt, model, temperature, and appearance",
        "kind": "component",
        "technology": "Payload Collection",
        "status": "proposed",
        "contract": {
          "expect": [
            "Each bot belongs to exactly one user",
            "Bot config includes a system prompt, model selection, and widget appearance settings"
          ]
        }
      },
      "parentId": "node-10"
    },
    {
      "id": "node-21",
      "type": "c4",
      "position": {
        "x": -80,
        "y": 260
      },
      "data": {
        "name": "Knowledge Base",
        "description": "Payload collection for documents the bot uses as context \u2014 uploaded files are chunked and embedded",
        "kind": "component",
        "technology": "Payload Collection",
        "status": "proposed",
        "contract": {
          "expect": [
            "Documents are chunked into segments of ~500 tokens with overlap",
            "Each chunk stores its embedding vector for similarity search"
          ],
          "never": [
            "Send entire documents to the LLM \u2014 always retrieve relevant chunks only"
          ]
        }
      },
      "parentId": "node-10"
    },
    {
      "id": "node-22",
      "type": "c4",
      "position": {
        "x": -80,
        "y": -80
      },
      "data": {
        "name": "Conversations",
        "description": "Payload collection for conversation logs \u2014 stores message history per session for review and analytics",
        "kind": "component",
        "technology": "Payload Collection",
        "status": "proposed"
      },
      "parentId": "node-10"
    },
    {
      "id": "node-23",
      "type": "c4",
      "position": {
        "x": 260,
        "y": 600
      },
      "data": {
        "name": "Billing",
        "description": "Manages Stripe subscriptions, usage metering, and plan limits",
        "kind": "component",
        "technology": "Payload Plugin, stripe",
        "status": "proposed",
        "contract": {
          "expect": [
            "Message usage is metered and reported to Stripe",
            "Bots are disabled when the user exceeds their plan's message quota"
          ]
        }
      },
      "parentId": "node-10"
    },
    {
      "id": "node-30",
      "type": "c4",
      "position": {
        "x": -420,
        "y": 260
      },
      "data": {
        "name": "Chat Handler",
        "description": "Receives a message and bot ID, retrieves relevant knowledge chunks, builds the prompt, and streams the LLM response",
        "kind": "component",
        "technology": "Next.js API Routes",
        "status": "proposed",
        "contract": {
          "expect": [
            "Responses are streamed via Server-Sent Events",
            "Each request validates the bot ID and checks the owner's usage quota before calling the LLM"
          ],
          "never": [
            "Expose the bot's system prompt or knowledge base content in the response"
          ]
        }
      },
      "parentId": "node-11"
    },
    {
      "id": "node-31",
      "type": "c4",
      "position": {
        "x": -420,
        "y": -80
      },
      "data": {
        "name": "Retriever",
        "description": "Performs vector similarity search against the knowledge base to find relevant context for the current message",
        "kind": "component",
        "technology": "MongoDB Atlas Search",
        "status": "proposed",
        "contract": {
          "expect": [
            "Returns top-k chunks ranked by cosine similarity",
            "Results are scoped to the specific bot's knowledge base"
          ]
        }
      },
      "parentId": "node-11"
    },
    {
      "id": "node-40",
      "type": "model",
      "data": {
        "name": "Bot",
        "description": "Chatbot configuration created by a user",
        "kind": "model",
        "status": "proposed",
        "properties": [
          {
            "label": "name",
            "description": "Display name for the bot"
          },
          {
            "label": "systemPrompt",
            "description": "Instructions that define the bot's persona and behavior"
          },
          {
            "label": "model",
            "description": "LLM model to use (e.g. gpt-4o-mini)"
          },
          {
            "label": "temperature",
            "description": "Sampling temperature for responses"
          },
          {
            "label": "appearance",
            "description": "Widget color, icon, and greeting message"
          },
          {
            "label": "ownerId",
            "description": "Reference to the user who owns this bot"
          },
          {
            "label": "active",
            "description": "Whether the bot is currently accepting messages"
          }
        ]
      },
      "parentId": "node-20",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-41",
      "type": "model",
      "data": {
        "name": "KnowledgeChunk",
        "description": "A chunk of a knowledge base document with its embedding vector",
        "kind": "model",
        "status": "proposed",
        "properties": [
          {
            "label": "botId",
            "description": "Which bot this chunk belongs to"
          },
          {
            "label": "documentId",
            "description": "Source document reference"
          },
          {
            "label": "content",
            "description": "Text content of the chunk (~500 tokens)"
          },
          {
            "label": "embedding",
            "description": "Vector embedding from OpenAI"
          },
          {
            "label": "metadata",
            "description": "Source filename, page number, chunk index"
          }
        ]
      },
      "parentId": "node-21",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-42",
      "type": "model",
      "data": {
        "name": "Message",
        "description": "A single message in a conversation",
        "kind": "model",
        "status": "proposed",
        "properties": [
          {
            "label": "role",
            "description": "user or assistant"
          },
          {
            "label": "content",
            "description": "Message text"
          },
          {
            "label": "sessionId",
            "description": "Groups messages into a conversation"
          },
          {
            "label": "botId",
            "description": "Which bot handled this message"
          },
          {
            "label": "createdAt",
            "description": "Timestamp"
          }
        ]
      },
      "parentId": "node-22",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-50",
      "type": "process",
      "data": {
        "name": "ingestDocument",
        "description": "Chunks an uploaded document, generates embeddings via @[OpenAI], and stores @[KnowledgeChunk] records in the @[Database]",
        "kind": "process",
        "status": "proposed",
        "contract": {
          "expect": [
            "Old chunks for the same document are deleted before re-ingesting",
            "Chunking preserves paragraph boundaries where possible"
          ]
        }
      },
      "parentId": "node-21",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-51",
      "type": "operation",
      "data": {
        "name": "handleChatMessage",
        "description": "Validates the request, retrieves context via @[Retriever], builds the prompt with conversation history, and streams the @[OpenAI] response",
        "kind": "operation",
        "status": "proposed"
      },
      "parentId": "node-30",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-52",
      "type": "operation",
      "data": {
        "name": "searchChunks",
        "description": "Embeds the query, runs a vector similarity search against @[KnowledgeChunk] records, and returns the top-k results",
        "kind": "operation",
        "status": "proposed"
      },
      "parentId": "node-31",
      "position": {
        "x": 0,
        "y": 0
      }
    },
    {
      "id": "node-53",
      "type": "operation",
      "data": {
        "name": "handleStripeWebhook",
        "description": "Processes Stripe webhook events for subscription changes, payment failures, and usage reporting",
        "kind": "operation",
        "status": "proposed",
        "contract": {
          "expect": [
            "Verifies Stripe webhook signature before processing",
            "Idempotent \u2014 safe to receive the same event multiple times"
          ]
        }
      },
      "parentId": "node-23",
      "position": {
        "x": 0,
        "y": 0
      }
    }
  ],
