    },
    {
      "id": "node-11",
      "type": "c4",
      "data": {
        "name": "Save Data",
        "description": "Persistent game state on disk \u2014 player progress, settings, and world state",
        "kind": "container",
        "technology": "JSON, user://",
        "shape": "cylinder",
        "status": "proposed",
        "contract": {
          "expect": [
            "Save files live in user:// directory",
            "Never overwrite without confirmation"
          ],
          "never": [
            "Store in res:// \u2014 read-only in exports"
          ]
        }
      },
      "parentId": "node-2",
      "position": {
        "x": 260,
        "y": -420
      }
    },
    {
      "id": "node-20",
      "type": "c4",
      "data": {
        "name": "Player Controller",
        "description": "Reads input and drives movement, animation, and collision response",
        "kind": "component",
        "technology": "CharacterBody3D, GDScript",
        "status": "proposed",
        "contract": {
          "expect": [
            "Uses move_and_slide() for collision",
            "All physics in _physics_process"
          ],
          "never": [
            "Modify position directly"
          ]
        }
      },
      "parentId": "node-10",
      "position": {
        "x": -80,
        "y": -40
      }
    },
    {
