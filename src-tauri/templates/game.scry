  "flows": [
    {
      "id": "scenario-1",
      "name": "Combat encounter",
      "description": "Player enters an area, enemies engage, combat resolves",
      "steps": [
        {
          "id": "step-1",
          "description": "@[Player Controller] enters a trigger zone in @[Levels]"
        },
        {
          "id": "step-2",
          "description": "@[AI] detects the player and enters attack state"
        },
        {
          "id": "step-3",
          "description": "@[AI] navigates toward the player and attacks"
        },
        {
          "id": "step-4",
          "description": "@[Combat System] detects hitbox overlap and calls @[apply_damage]",
          "branches": [
            {
              "condition": "if: health reaches zero",
              "steps": [
                {
                  "id": "step-4a",
                  "description": "@[Combat System] emits death signal, enemy drops loot"
                }
              ]
            },
            {
              "condition": "else: target survives",
              "steps": [
                {
                  "id": "step-4b",
                  "description": "@[HUD] flashes damage indicator"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "scenario-2",
      "name": "Save and load",
      "description": "Player saves progress and resumes later",
      "steps": [
        {
          "id": "step-1",
          "description": "@[Player] opens the pause menu in @[Menus]"
        },
        {
          "id": "step-2",
          "description": "@[save_game] collects @[PlayerState]"
        },
        {
          "id": "step-3",
          "description": "@[Save System] writes to @[Save Data]"
        },
        {
          "id": "step-4",
          "description": "Later, @[Player] selects Load from @[Menus]"
        },
        {
          "id": "step-5",
          "description": "@[load_game] reads @[Save Data] and restores @[PlayerState]"
        },
        {
          "id": "step-6",
          "description": "@[Scene Manager] loads the saved level"
        }
      ]
    }
  ],
  "contract": {
    "expect": [
      "Gameplay logic in _physics_process only",
      "Scenes are self-contained and independently testable",
      "Cross-system communication uses signals"
    ],
    "never": [
      "Gameplay logic in _process",
      "Global state outside Autoload singletons"
    ]
  },
  "startingLevel": "system",
